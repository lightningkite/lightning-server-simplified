{
  "compilerOptions": {
    "outDir": "dist/",
    "declaration": true,
    "strict": true,
    "sourceMap": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "allowJs": true,
    "baseUrl": "src"
  },
  "include": ["src/**/*", "resources/**/*"]
}